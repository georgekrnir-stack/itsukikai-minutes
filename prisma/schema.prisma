generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  name           String
  role           String          @default("user") // "admin" | "user"
  createdAt      DateTime        @default(now())
  transcriptions Transcription[]
}

model CustomDictionary {
  id            String   @id @default(uuid())
  correctTerm   String
  incorrectTerm String
  category      String
  isKeyterm     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Transcription {
  id               String   @id @default(uuid())
  title            String
  category         String?  // 経営会議, 委員会, プロジェクト, 研修・教育, 部門会議, その他
  status           String   @default("uploading") // uploading | transcribing | correcting | analyzing | completed | error
  originalFilename String
  fileSize         Int      // バイト数
  durationSeconds  Int?     // 音声の長さ（秒）。完了後に設定
  speakerCount     Int?     // 検出された話者数。完了後に設定
  utteranceCount   Int?     // 発言ブロック数。完了後に設定
  languageCode     String?  // 検出された言語コード
  transcriptText   String?  // 全体のプレーンテキスト（APIのtextフィールド）
  utterances       Json?    // 整形済みutterances配列（JSON）
  speakers         Json?    // 話者IDリスト（JSON配列）
  speakerMapping   Json?    // 話者名マッピング（Phase 4で使用）
  correctedUtterances Json?    // 清書後のutterances（変更履歴付き）
  correctionSummary   String?  // 清書の要約
  speakerSuggestions  Json?    // AI話者分析の提案（nameSuggestions, mergeGroups）
  errorMessage     String?  // エラー時のメッセージ
  processingTimeMs Int?     // ElevenLabs APIの処理時間（ミリ秒）
  userId           String?  // nullable for backward compatibility
  user             User?    @relation(fields: [userId], references: [id])
  minutes          Minutes?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Minutes {
  id              String        @id @default(uuid())
  transcriptionId String        @unique
  transcription   Transcription @relation(fields: [transcriptionId], references: [id])
  content         String
  isEdited        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PromptTemplate {
  id        String   @id @default(uuid())
  name      String   @unique  // "correction" | "minutes"
  content   String
  updatedAt DateTime @updatedAt
}
